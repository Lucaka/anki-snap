    "@vitest/coverage-v8": "^1.0.0",
    "@vue/test-utils": "^2.4.0",
    "autoprefixer": "^10.4.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite-plus": "^0.1.16",
    "vitest": "^1.0.0",
    "vue-tsc": "^2.0.0"
  },
  "engines": {
    "node": ">=22.0.0",
